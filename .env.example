# MissionOS environment template.
# Copy to `.env` and fill in values: cp .env.example .env

# Required only when MISSIONOS_LLM_BACKEND=gemini.
# Get a key at https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Use Google AI Studio (false) or Vertex AI (true). Leave false for the quickstart.
GOOGLE_GENAI_USE_VERTEXAI=false

# LLM backend.
#
# MissionOS is designed around an LLM-in-the-loop chat path. Set this to
# `gemini` or `ollama` for the intended MissionOS experience.
#
# `off` is a safe development fallback for boundary tests. It disables
# LLM-backed ADK paths in CLI-managed Gateway children and should not be treated
# as the main product experience.
# - gemini: Google ADK/Gemini (requires GOOGLE_API_KEY or Vertex credentials)
# - ollama: local Ollama through ADK LiteLLM; no GOOGLE_API_KEY is propagated
# - off: development fallback only
MISSIONOS_LLM_BACKEND=off
MISSIONOS_OLLAMA_MODEL=gemma4:26b
MISSIONOS_OLLAMA_BASE_URL=http://localhost:11434

# Route-level LLM flags.
#
# Leave these enabled when selecting `gemini` or `ollama` so the chat path can
# use LLM-backed planning and repair. When MISSIONOS_LLM_BACKEND=off, the
# CLI-managed Gateway process forces them to 0 even though this template keeps
# the intended LLM route flags visible.
MISSIONOS_AGENT_RUNTIME_ADK_ENABLED=1
MISSIONOS_CHIEF_ROUTE_SEMANTIC_ADK_ENABLED=1
MISSIONOS_LLM_DIALOGUE_ROUTER_ADK_ENABLED=1
MISSIONOS_LLM_REPAIR_PLANNER_ADK_ENABLED=1
MISSIONOS_LLM_RESPONSE_PLANNER_ADK_ENABLED=1
MISSIONOS_REAL_HARDWARE_ARM_DISARM_PLANNER_ADK_ENABLED=1

# Local models are often slower than hosted Gemini. Increase these when
# explicitly running Gemma through Ollama on a workstation.
MISSIONOS_LLM_DIALOGUE_ROUTER_TIMEOUT_SECONDS=180
MISSIONOS_CHIEF_ROUTE_SEMANTIC_TIMEOUT_SECONDS=240
MISSIONOS_AGENT_RUNTIME_TIMEOUT_SECONDS=240
MISSIONOS_LLM_REPAIR_PLANNER_TIMEOUT_SECONDS=180
MISSIONOS_LLM_RESPONSE_PLANNER_TIMEOUT_SECONDS=180
MISSIONOS_REAL_HARDWARE_ARM_DISARM_PLANNER_TIMEOUT_SECONDS=180

# Intended hosted chat path:
# MISSIONOS_LLM_BACKEND=gemini
# GOOGLE_API_KEY=...

# Local chat path:
# MISSIONOS_LLM_BACKEND=ollama
# MISSIONOS_OLLAMA_MODEL=gemma4:26b

# Optional per-agent override:
# MISSIONOS_AGENT_MISSIONOS_RUNTIME_RECOVERY_AGENT_LLM_BACKEND=gemini
# MISSIONOS_AGENT_MISSIONOS_RUNTIME_RECOVERY_AGENT_MODEL_ID=gemini-3.1-flash-lite-preview

# Optional: override the default planner model.
# AGENT_MODEL=gemini-3.1-flash-lite-preview
